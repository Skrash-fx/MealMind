@page "/recepten"
@inject IHttpClientFactory ClientFactory
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Recepten</PageTitle>

<div class="fade-in">
    <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:24px;">
        <div>
            <div class="page-title">Alle Recepten</div>
            <div class="page-subtitle">Ontdek en beheer je recepten</div>
        </div>
        <a class="btn-mm" href="/recepten/aanmaken">+ Nieuw recept</a>
    </div>

    @if (recepten == null)
    {
        <div class="loader">Recepten laden...</div>
    }
    else if (!recepten.Any())
    {
        <div class="mm-card" style="text-align:center; padding:48px;">
            <div class="page-title" style="margin-bottom:8px;">Nog geen recepten</div>
            <div class="page-subtitle" style="margin-bottom:20px;">Voeg je eerste recept toe om te beginnen.</div>
            <a class="btn-mm" href="/recepten/aanmaken">Recept toevoegen</a>
        </div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var r in recepten)
            {
                <div class="mm-card" style="cursor:pointer;" @onclick="() => OpenDetail(r.idRecept)">
                    <h4 style="color:var(--green-dark); margin-bottom:8px; font-size:1.05rem;">@r.receptNaam</h4>
                    <p style="color:var(--text-muted); margin-bottom:14px; font-size:0.9rem; line-height:1.5;">@r.receptBeshrijving</p>
                    <div style="display:flex; gap:6px; flex-wrap:wrap;">
                        @foreach (var cat in r.categorieen)
                        {
                            <span class="badge-mm">@cat</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ReceptItem>? recepten;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var client = ClientFactory.CreateClient("MealMindAPI");
            recepten = await client.GetFromJsonAsync<List<ReceptItem>>("recepten") ?? new();
            StateHasChanged();
        }
    }

    private void OpenDetail(int id) => Nav.NavigateTo($"/recepten/{id}");

    public class ReceptItem
    {
        public int idRecept { get; set; }
        public string receptNaam { get; set; } = "";
        public string receptBeshrijving { get; set; } = "";
        public List<string> categorieen { get; set; } = new();
    }
}
