@page "/login"
@inject HttpClient Http
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>MealMind - Login</PageTitle>

<div style="max-width: 420px; margin: 60px auto; padding: 40px; background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);">

    <div style="text-align: center; margin-bottom: 30px;">
        <div style="font-size: 48px;">🍽️</div>
        <h2 style="font-weight: 700; color: #2c3e50; margin-top: 8px;">MealMind</h2>
    </div>

    <!-- Tabs -->
    <div style="display: flex; margin-bottom: 30px; border-bottom: 2px solid #e0e0e0;">
        <button @onclick='() => activeTab = "login"'
                style="flex: 1; padding: 12px; border: none; background: none; font-weight: 600; cursor: pointer; font-size: 16px;
                       color: @(activeTab == "login" ? "#11998e" : "#999");
                       border-bottom: @(activeTab == "login" ? "2px solid #11998e" : "none");
                       margin-bottom: -2px;">
            Inloggen
        </button>
        <button @onclick='() => activeTab = "register"'
                style="flex: 1; padding: 12px; border: none; background: none; font-weight: 600; cursor: pointer; font-size: 16px;
                       color: @(activeTab == "register" ? "#11998e" : "#999");
                       border-bottom: @(activeTab == "register" ? "2px solid #11998e" : "none");
                       margin-bottom: -2px;">
            Registreren
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="padding: 12px 16px; background: #fee; border: 1px solid #fcc; border-radius: 8px; color: #c00; margin-bottom: 20px;">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div style="padding: 12px 16px; background: #d4edda; border: 1px solid #c3e6cb; border-radius: 8px; color: #155724; margin-bottom: 20px;">
            @successMessage
        </div>
    }

    <!-- Login Tab -->
    @if (activeTab == "login")
    {
        <div class="mb-4">
            <label style="font-weight: 500; margin-bottom: 6px; display: block;">GSM-nummer</label>
            <input type="text" class="form-control" placeholder="Bijv. 468003451" @bind="gsm" />
            <small style="color: #999;">Log in met je GSM-nummer</small>
        </div>
        <button @onclick="LoginUser" disabled="@isLoading"
                style="width: 100%; padding: 12px; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 16px; cursor: pointer;">
            @(isLoading ? "Bezig..." : "Inloggen")
        </button>
    }

    <!-- Register Tab -->
    @if (activeTab == "register")
    {
        <div class="mb-3">
            <label style="font-weight: 500; margin-bottom: 6px; display: block;">Voornaam</label>
            <input type="text" class="form-control" placeholder="Voornaam" @bind="regVoornaam" />
        </div>
        <div class="mb-3">
            <label style="font-weight: 500; margin-bottom: 6px; display: block;">Achternaam</label>
            <input type="text" class="form-control" placeholder="Achternaam" @bind="regAchternaam" />
        </div>
        <div class="mb-4">
            <label style="font-weight: 500; margin-bottom: 6px; display: block;">GSM-nummer</label>
            <input type="text" class="form-control" placeholder="Bijv. 0468003451" @bind="regGsm" />
        </div>
        <button @onclick="RegisterUser" disabled="@isLoading"
                style="width: 100%; padding: 12px; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 16px; cursor: pointer;">
            @(isLoading ? "Bezig..." : "Registreren")
        </button>
    }
</div>

@code {
    private string activeTab = "login";

    // Login
    private string gsm = "";

    // Register
    private string regVoornaam = "";
    private string regAchternaam = "";
    private string regGsm = "";

    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    private async Task LoginUser()
    {
        errorMessage = "";
        isLoading = true;

        try
        {
            var url = $"/login?gsm={Uri.EscapeDataString(gsm)}";
            var response = await Http.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var user = await response.Content.ReadFromJsonAsync<GebruikerDto>();
                await JS.InvokeVoidAsync("sessionStorage.setItem", "userId", user!.IdGebruiker.ToString());
                await JS.InvokeVoidAsync("sessionStorage.setItem", "userName", user.GebruikerVoorNaam);
                Navigation.NavigateTo("/recepten");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Geen gebruiker gevonden met dit GSM-nummer.";
            }
            else
            {
                errorMessage = "Onbekende fout bij het inloggen.";
            }
        }
        catch
        {
            errorMessage = "Kan geen verbinding maken met de server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RegisterUser()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(regVoornaam) || string.IsNullOrWhiteSpace(regAchternaam) || string.IsNullOrWhiteSpace(regGsm))
        {
            errorMessage = "Vul alle velden in.";
            return;
        }

        isLoading = true;

        try
        {
            var url = $"/gebruiker?voornaam={Uri.EscapeDataString(regVoornaam)}&achternaam={Uri.EscapeDataString(regAchternaam)}&gsm={Uri.EscapeDataString(regGsm)}";
            var response = await Http.PostAsync(url, null);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Registratie gelukt! Je kan nu inloggen.";
                activeTab = "login";
                gsm = regGsm;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                errorMessage = "Dit GSM-nummer is al geregistreerd.";
            }
            else
            {
                errorMessage = "Fout bij registreren. Probeer opnieuw.";
            }
        }
        catch
        {
            errorMessage = "Kan geen verbinding maken met de server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class GebruikerDto
    {
        public int IdGebruiker { get; set; }
        public string GebruikerVoorNaam { get; set; } = string.Empty;
        public string GebruikerAchternaam { get; set; } = string.Empty;
    }
}
