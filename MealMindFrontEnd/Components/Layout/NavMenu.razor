@using Microsoft.AspNetCore.Components.Routing
@inject UserState UserState
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable
@rendermode InteractiveServer
@using System.Text.Json

<header class="topbar">
    <a class="topbar-brand" href="/home">
        <img src="/logoMealMind.jpg" style="height:36px; width:36px; object-fit:contain;" alt="MealMind logo" />
        <div>
            <div class="brand-name">MealMind</div>
        </div>
    </a>

    <nav class="topbar-nav">
        <NavLink href="/home" Match="NavLinkMatch.All">Home</NavLink>
        <NavLink href="/recepten">Recepten</NavLink>
        <NavLink href="/planning">Planning</NavLink>
    </nav>

    <div class="topbar-right">
        @if (UserState.IsLoggedIn)
        {
            <div class="user-badge">@UserState.UserName</div>
            <button class="btn-logout" @onclick="Logout">Uitloggen</button>
        }
        else
        {
            <a class="btn-mm" href="/login">Inloggen</a>
        }
    </div>
</header>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var json = await JS.InvokeAsync<string>("localStorage.getItem", "mmUser");
                if (!string.IsNullOrEmpty(json))
                {
                    var obj = JsonSerializer.Deserialize<LocalUser?>(json);
                    if (obj != null)
                    {
                        var naam = obj.GebruikerUsername ?? obj.GebruikerEmail ?? "";
                        if (!string.IsNullOrEmpty(naam))
                        {
                            UserState.UserId = obj.IdGebruiker;
                            UserState.UserName = naam;
                            StateHasChanged();
                        }
                    }
                }
            }
            catch { }
        }
    }

    private async Task Logout()
    {
        UserState.UserId = 0;
        UserState.UserName = "";
        await JS.InvokeVoidAsync("localStorage.removeItem", "mmUser");
        await JS.InvokeVoidAsync("localStorage.removeItem", "userId");
        Nav.NavigateTo("/");
    }

    protected override void OnInitialized()
    {
        UserState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
    }

    private class LocalUser
    {
        public int IdGebruiker { get; set; }
        public string? GebruikerUsername { get; set; }
        public string? GebruikerEmail { get; set; }
    }
}
