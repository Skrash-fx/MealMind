@page "/planning"
@inject IHttpClientFactory ClientFactory
@inject UserState UserState
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Text.Json
@rendermode InteractiveServer

<PageTitle>Weekplanning</PageTitle>

<div class="fade-in">

    @if (geladen && !UserState.IsLoggedIn)
    {
        <div class="mm-card" style="text-align:center; padding:48px;">
            <div style="font-size:2.5rem; margin-bottom:12px;">🔒</div>
            <div class="page-title" style="margin-bottom:8px;">Niet ingelogd</div>
            <div class="page-subtitle">Log in om je weekplanning te bekijken en beheren.</div>
            <a class="btn-mm" href="/login">Inloggen</a>
        </div>
    }
    else if (!geladen)
    {
        <div class="loader">⏳ Even geduld...</div>
    }
    else
    {
        <!-- Header -->
        <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:24px;">
            <div>
                <div class="page-title">📅 Weekplanning</div>
                <div class="page-subtitle">Plan je maaltijden voor de komende 7 dagen</div>
            </div>

            @if (heeftPlanning)
            {
                <div style="display:flex; gap:10px;">
                    <button class="btn-mm-outline" @onclick="Genereer" disabled="@bezig">🔀 Hergenereer</button>
                    <button class="btn-mm" @onclick="OpslaanPlanning" disabled="@bezig">
                        @if (bezig)
                        {
                            <span>⏳ Bezig...</span>
                        }
                        else
                        {

                            <span>💾 Opslaan</span>
                        }
                    </button>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(melding))
        {
            <div class="mm-card" style="background:@(meldingFout ? "#fff3f0" : "#f0fdf7"); border:1.5px solid @(meldingFout ? "#f2c2b8" : "#b2e8d0"); color:@(meldingFout ? "#8a2b11" : "#1a5c45"); padding:14px; margin-bottom:18px;">
                @melding
            </div>
        }

        <!-- Lege staat -->
        @if (!heeftPlanning)
        {
            <div class="mm-card" style="text-align:center; padding:56px 32px;">
                <div style="font-size:3rem; margin-bottom:16px;">🍽️</div>
                <div class="page-title" style="margin-bottom:8px;">Nog geen planning</div>
                <div class="page-subtitle" style="margin-bottom:24px;">
                    Genereer automatisch een weekplanning op basis van je recepten,<br />
                    of voeg zelf maaltijden toe per dag via de dropdown.
                </div>
                <button class="btn-mm" @onclick="Genereer" disabled="@bezig">
                    @if (bezig)
                    {
                        <span>⏳ Genereren...</span>
                    }
                    else
                    {

                        <span>🔀 Genereer planning</span>
                    }
                </button>
            </div>
        }
        else
        {
            <!-- Planning kaarten per dag -->
            <div style="display:grid; gap:14px;">
                @foreach (var dag in planning)
                {
                    <div class="mm-card" style="display:grid; grid-template-columns:140px 1fr auto; align-items:center; gap:16px;">

                        <!-- Datum blok -->
                        <div style="background:var(--grad-pale); border-radius:12px; padding:12px 14px; text-align:center;">
                            <div style="font-family:'Poppins',sans-serif; font-weight:800; font-size:1rem; color:var(--green-dark);">@DagNaam(dag.datum)</div>
                            <div style="font-size:0.82rem; color:var(--text-muted); margin-top:2px;">@dag.datum?.ToString("dd/MM")</div>
                        </div>

                        <!-- Recept info + dropdown -->
                        <div>
                            @if (string.IsNullOrEmpty(dag.receptNaam))
                            {
                                <div style="color:#b0c8bc; font-style:italic; font-size:0.95rem; margin-bottom:8px;">Geen maaltijd gepland</div>
                            }
                            else
                            {
                                <div style="font-family:'Poppins',sans-serif; font-weight:700; font-size:1rem; color:var(--green-dark); margin-bottom:3px;">@dag.receptNaam</div>
                                @if (!string.IsNullOrEmpty(dag.beschrijving))
                                {
                                    <div style="font-size:0.85rem; color:var(--text-muted); margin-bottom:6px;">@dag.beschrijving</div>
                                }
                            }

                            <select @onchange="e => WijzigDagLokaal(dag, e.Value?.ToString())"
                                    style="margin-top:6px; padding:7px 12px; border-radius:8px; border:1.5px solid rgba(26,92,69,0.14); font-family:'DM Sans',sans-serif; font-size:0.88rem; color:var(--text); background:var(--white); cursor:pointer; max-width:280px;">
                                <option value="">— Kies recept —</option>
                                @foreach (var r in alleRecepten)
                                {
                                    <option value="@r.idRecept" selected="@(dag.fkRecept == r.idRecept)">@r.receptNaam</option>
                                }
                            </select>
                        </div>

                        <!-- Acties -->
                        <div style="display:flex; flex-direction:column; gap:8px; align-items:flex-end;">
                            @if (dag.fkRecept > 0)
                            {
                                <a class="btn-mm-outline" href="/recepten/@dag.fkRecept"
                                   style="white-space:nowrap; font-size:0.85rem; padding:7px 14px;">👁️ Bekijk</a>
                            }
                            <button @onclick="() => VerwijderDag(dag)"
                                    style="background:none; border:1.5px solid #f2c2b8; color:#c0392b; border-radius:8px; padding:6px 12px; font-size:0.82rem; cursor:pointer; font-family:'DM Sans',sans-serif;">
                                🗑️ Leeg
                            </button>
                        </div>

                    </div>
                }
            </div>

            <!-- Opslaan knop onderaan -->
            <div style="margin-top:28px; display:flex; justify-content:flex-end; gap:12px;">
                <button class="btn-mm-outline" @onclick="Genereer" disabled="@bezig">🔀 Hergenereer</button>
                <button class="btn-mm" @onclick="OpslaanPlanning" disabled="@bezig">
                    @if (bezig)
                    {
                        <span>⏳ Opslaan...</span>
                    }
                    else
                    {

                        <span>💾 Planning opslaan</span>
                    }
                </button>
            </div>
        }
    }
</div>

@code {
    private List<PlanningItem> planning = new();
    private List<ReceptKeuze> alleRecepten = new();
    private bool geladen = false;
    private bool bezig = false;
    private bool heeftPlanning => planning.Any(d => d.fkRecept > 0);
    private string melding = "";
    private bool meldingFout = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!UserState.IsLoggedIn)
            {
                try
                {
                    var json = await JS.InvokeAsync<string>("localStorage.getItem", "mmUser");
                    if (!string.IsNullOrEmpty(json))
                    {
                        var obj = JsonSerializer.Deserialize<LocalUser?>(json);
                        if (obj != null && obj.IdGebruiker > 0)
                        {
                            UserState.UserId = obj.IdGebruiker;
                            UserState.UserName = obj.GebruikerUsername ?? obj.GebruikerEmail ?? "";
                        }
                    }
                }
                catch { }
            }

            geladen = true;

            if (UserState.IsLoggedIn)
                await LaadData();

            StateHasChanged();
        }
    }

    private async Task LaadData()
    {
        try
        {
            var client = ClientFactory.CreateClient("MealMindAPI");
            var raw = await client.GetFromJsonAsync<List<PlanningDto>>($"gebruikers/{UserState.UserId}/planning") ?? new();
            alleRecepten = await client.GetFromJsonAsync<List<ReceptKeuze>>("recepten") ?? new();

            // Bouw altijd 7 dagen op vanaf vandaag
            planning = new List<PlanningItem>();
            var vandaag = DateOnly.FromDateTime(DateTime.Today);
            for (int i = 0; i < 7; i++)
            {
                var datum = vandaag.AddDays(i);
                var match = raw.FirstOrDefault(d =>
                 DateOnly.TryParse(d.datum, out var parsed) && parsed == datum);
                planning.Add(new PlanningItem
                {
                    datum = datum,
                    fkRecept = match?.fkRecept ?? 0,
                    receptNaam = match?.receptNaam ?? "",
                    beschrijving = match?.beschrijving ?? ""
                });
            }
        }
        catch (Exception ex)
        {
            ToonMelding("Kon planning niet laden: " + ex.Message, fout: true);
        }
    }

    private async Task Genereer()
    {
        bezig = true;
        melding = "";
        StateHasChanged();
        try
        {
            var client = ClientFactory.CreateClient("MealMindAPI");
            await client.PostAsync($"gebruikers/{UserState.UserId}/planning/genereer", null);
            await LaadData();
            ToonMelding("✅ Planning gegenereerd! Pas aan waar nodig en klik op Opslaan.");
        }
        catch (Exception ex)
        {
            ToonMelding("Fout bij genereren: " + ex.Message, fout: true);
        }
        finally
        {
            bezig = false;
            StateHasChanged();
        }
    }

    private async Task OpslaanPlanning()
    {
        bezig = true;
        melding = "";
        StateHasChanged();

        try
        {
            var client = ClientFactory.CreateClient("MealMindAPI");
            foreach (var dag in planning.Where(d => d.datum.HasValue))
            {
                if (dag.fkRecept > 0)
                {
                    // Sla dag op met recept
                    await client.PutAsJsonAsync(
                        $"gebruikers/{UserState.UserId}/planning/{dag.datum!.Value:yyyy-MM-dd}",
                        new { ReceptId = dag.fkRecept });
                }
            }
            ToonMelding("✅ Planning opgeslagen! Je ziet deze terug na het opnieuw inloggen.");
        }
        catch (Exception ex)
        {
            ToonMelding("Fout bij opslaan: " + ex.Message, fout: true);
        }
        finally
        {
            bezig = false;
            StateHasChanged();
        }
    }

    private void WijzigDagLokaal(PlanningItem dag, string? waarde)
    {
        if (int.TryParse(waarde, out var receptId) && receptId > 0)
        {
            dag.fkRecept = receptId;
            var recept = alleRecepten.FirstOrDefault(r => r.idRecept == receptId);
            dag.receptNaam = recept?.receptNaam ?? "";
            dag.beschrijving = "";
        }
    }

    private void VerwijderDag(PlanningItem dag)
    {
        dag.fkRecept = 0;
        dag.receptNaam = "";
        dag.beschrijving = "";
    }

    private void ToonMelding(string tekst, bool fout = false)
    {
        melding = tekst;
        meldingFout = fout;
    }

    private string DagNaam(DateOnly? datum)
    {
        if (!datum.HasValue) return "";
        return datum.Value.DayOfWeek switch
        {
            DayOfWeek.Monday => "Maandag",
            DayOfWeek.Tuesday => "Dinsdag",
            DayOfWeek.Wednesday => "Woensdag",
            DayOfWeek.Thursday => "Donderdag",
            DayOfWeek.Friday => "Vrijdag",
            DayOfWeek.Saturday => "Zaterdag",
            DayOfWeek.Sunday => "Zondag",
            _ => ""
        };
    }

    private class LocalUser
    {
        public int IdGebruiker { get; set; }
        public string? GebruikerUsername { get; set; }
        public string? GebruikerEmail { get; set; }
    }

    public class PlanningDto
    {
        public string datum { get; set; } = "";  // string ipv DateOnly
        public int fkRecept { get; set; }
        public string receptNaam { get; set; } = "";
        public string beschrijving { get; set; } = "";
    }

    public class PlanningItem
    {
        public DateOnly? datum { get; set; }
        public int fkRecept { get; set; }
        public string receptNaam { get; set; } = "";
        public string beschrijving { get; set; } = "";
    }

    public class ReceptKeuze
    {
        public int idRecept { get; set; }
        public string receptNaam { get; set; } = "";
    }
}
