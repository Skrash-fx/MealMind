@page "/"
@page "/home"
<PageTitle>Home</PageTitle>

<div class="page-intro">
    <div style="display:flex; align-items:center; gap:18px; flex-wrap:wrap;">
        <div style="font-size:2.4rem;">🥗</div>
        <div>
            <div class="page-title">Welkom bij MealMind</div>
            <div class="page-subtitle">Snel je week plannen en lekkere recepten ontdekken</div>
        </div>
    </div>

    <div style="margin-top:22px;" class="card-grid">
        <a class="mm-card" href="recepten">
            <h3 style="color:var(--green-dark); margin-bottom:8px;">🍽️ Recepten</h3>
            <p style="color:#666;">Bekijk, zoek en maak nieuwe recepten.</p>
            <div style="margin-top:12px;"><span class="btn-mm">Naar recepten</span></div>
