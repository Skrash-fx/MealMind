@page "/mijnplanning"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Mijn Planning</PageTitle>

<div class="fade-in">
    <div class="page-title">📅 Mijn Planning</div>
    <div class="page-subtitle">Jouw maaltijden voor de komende week</div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="mm-card" style="background:#fff3f0; border:1px solid #f2c2b8; color:#8a2b11; padding:12px; margin:12px 0;">
            <strong>Fout:</strong>
            <div style="margin-top:6px;">@errorMessage</div>
        </div>
    }

    @if (!isLoaded)
    {
        <div class="loader">⏳ Planning laden...</div>
    }
    else if (planningItems == null || !planningItems.Any())
    {
        <div class="mm-card" style="text-align:center; padding: 48px;">
            <div style="font-size:3rem; margin-bottom:12px;">🍽️</div>
            <div style="font-size:1.1rem; color: var(--green-light); margin-bottom:20px;">Nog geen maaltijden gepland</div>
            <a href="/recepten" class="btn-mm">Bekijk recepten</a>
        </div>
    }
    else
    {
        <div class="planning-week">
            @foreach (var item in planningItems)
            {
                <div class="planning-day @(string.IsNullOrEmpty(item.ReceptNaam) ? "empty" : "")" @onclick="() => OpenDetail(item.FkRecept)">
                    <div class="day-name">@item.DagNaam</div>
                    <div class="day-date">@item.Datum.ToString("dd/MM")</div>
                    <div class="day-meal">@(string.IsNullOrEmpty(item.ReceptNaam) ? "Leeg" : item.ReceptNaam)</div>
                </div>
            }
        </div>

        <div style="margin-top: 32px;">
            <h3 style="font-size:1.2rem; font-weight:700; color:var(--green-dark); margin-bottom:16px;">Alle geplande maaltijden</h3>
            <div class="card-grid">
                @foreach (var item in planningItems.Where(p => !string.IsNullOrEmpty(p.ReceptNaam)))
                {
                    <div class="mm-card">
                        <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:10px;">
                            <span class="badge-mm">@item.DagNaam</span>
                            <span style="font-size:0.82rem; color:#888;">@item.Datum.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div style="font-size:1.05rem; font-weight:700; color:var(--green-dark); margin-bottom:6px;">@item.ReceptNaam</div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<PlanningItem>? planningItems;
    private bool isLoaded = false;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var userIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "userId");
            if (string.IsNullOrEmpty(userIdStr) || !int.TryParse(userIdStr, out var userId))
            {
                Navigation.NavigateTo("/login");
                return;
            }

            await LaadPlanning(userId);
            isLoaded = true;
            StateHasChanged();
        }
    }

    private async Task LaadPlanning(int userId)
    {
        try
        {
            var data = await Http.GetFromJsonAsync<List<PlanningDto>>($"api/gebruikers/{userId}/planning");

            // Bouw een week op (7 dagen vanaf vandaag)
            planningItems = new List<PlanningItem>();
            var vandaag = DateTime.Today;
            var dagNamen = new[] { "Zo", "Ma", "Di", "Wo", "Do", "Vr", "Za" };

            for (int i = 0; i < 7; i++)
            {
                var datum = vandaag.AddDays(i);
                var match = data?.FirstOrDefault(d => d.Datum.Date == datum.Date);
                planningItems.Add(new PlanningItem
                {
                    Datum = datum,
                    DagNaam = dagNamen[(int)datum.DayOfWeek],
                    ReceptNaam = match?.ReceptNaam ?? "",
                    FkRecept = match?.FkRecept
                });
            }

            if (data == null)
            {
                // geen data terug — laat gebruiker weten dat demo-data wordt getoond
                errorMessage = "Geen planning van de server ontvangen; demo-data wordt getoond.";
            }
            else
            {
                errorMessage = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Kon planning niet laden: " + ex.Message;
            planningItems = GenereerDemoPlanning();
        }
    }

    private async Task RetryLoad()
    {
        isLoaded = false;
        StateHasChanged();

        var userIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "userId");
        if (string.IsNullOrEmpty(userIdStr) || !int.TryParse(userIdStr, out var userId))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LaadPlanning(userId);
        isLoaded = true;
        StateHasChanged();
    }

    private List<PlanningItem> GenereerDemoPlanning()
    {
        var vandaag = DateTime.Today;
        var dagNamen = new[] { "Zo", "Ma", "Di", "Wo", "Do", "Vr", "Za" };
        var recepten = new[] { "Spaghetti bolognese", "Kip curry", "Zalm uit de oven", "", "Vegetarische lasagne", "Stoofvlees", "" };

        return Enumerable.Range(0, 7).Select(i => new PlanningItem
        {
            Datum = vandaag.AddDays(i),
            DagNaam = dagNamen[(int)vandaag.AddDays(i).DayOfWeek],
            ReceptNaam = recepten[i]
        }).ToList();
    }

    private void OpenDetail(int? fkRecept)
    {
        if (fkRecept.HasValue)
            Navigation.NavigateTo($"/recepten/{fkRecept.Value}");
    }

    // DTO van API
    public class PlanningDto
    {
        public DateTime Datum { get; set; }
        public int? FkRecept { get; set; }
        public string ReceptNaam { get; set; } = "";
        public string Beschrijving { get; set; } = "";
    }

    // Intern model
    public class PlanningItem
    {
        public DateTime Datum { get; set; }
        public string DagNaam { get; set; } = "";
        public string ReceptNaam { get; set; } = "";
        public int? FkRecept { get; set; }
    }
}